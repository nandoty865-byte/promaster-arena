generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sport {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  tournaments Tournament[]
  templates   TournamentTemplate[]
}

model Tournament {
  id          Int      @id @default(autoincrement())
  name        String
  sportId     Int
  playerCount Int
  format      String
  status      String   @default("draft")
  tableCount  Int
  createdAt   DateTime @default(now())
organizationId Int?
organization   Organization? @relation(fields: [organizationId], references: [id])
seasonId       Int?
season         Season? @relation(fields: [seasonId], references: [id])
publicSlug     String? @unique
location     String?
eventDate    DateTime?
eventTime    String?
prize        String?
rules        String?
youtubeUrl   String?
  sport   Sport   @relation(fields: [sportId], references: [id])
  players Player[]
  matches Match[]
}

model Season {
  id                  Int      @id @default(autoincrement())
  organizationId      Int
  name                String
  tournamentCount     Int
  playerCount         Int
  startDate           DateTime?
  endDate             DateTime?
  locations           String?
  rules               String?
  prize               String?
  status              String   @default("draft")
  championName        String?
  championPoints      Int?
  createdAt           DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  tournaments  Tournament[]
}

model Player {
  id           Int      @id @default(autoincrement())
  name         String
  nickname     String?
  tournamentId Int?
  createdAt    DateTime @default(now())

  tournament Tournament? @relation(fields: [tournamentId], references: [id])
}

model Match {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  playerAId    Int?
  playerBId    Int?
  winnerId     Int?
  loserId      Int?
  tableNumber  Int?
  round        Int
  bracketType  String
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
}

model TournamentTemplate {
  id              Int    @id @default(autoincrement())
  sportId         Int
  name            String
  playerCount     Int
  format          String
  eliminationType String

  sport Sport @relation(fields: [sportId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  phone String?
emailVerified Boolean @default(false)
emailVerifyToken String?
organizationId Int?
organization   Organization? @relation(fields: [organizationId], references: [id])
}

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
address String?
street String?
number String?
complement String?
country String?
state String?
city String?
logoUrl String?
plan        String    @default("trial")
trialEndsAt DateTime?
planExpiresAt DateTime?
maxUsers Int @default(1)
tournamentCredits Int @default(0)
  users       User[]
  tournaments Tournament[]
  seasons     Season[]
}

model Payment {
  id             Int      @id @default(autoincrement())
  mercadoPagoId String?  @unique
  organizationId Int?
  plan           String
  amount         Float
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  paidAt         DateTime?
}
