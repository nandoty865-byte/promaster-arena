generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sport {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  tournaments Tournament[]
  templates   TournamentTemplate[]
}

model Tournament {
  id          Int      @id @default(autoincrement())
  name        String
  sportId     Int
  playerCount Int
  format      String
  status      String   @default("draft")
  tableCount  Int
  createdAt   DateTime @default(now())
organizationId Int?
organization   Organization? @relation(fields: [organizationId], references: [id])
seasonId       Int?
season         Season? @relation(fields: [seasonId], references: [id])
publicSlug     String? @unique
location     String?
venueAddress String?
eventDate    DateTime?
eventTime    String?
prize        String?
rules        String?
broadcastType String @default("none")
youtubeUrl   String?
obsStreamUrl String?
registrationOpen Boolean @default(true)
registrationFee Float?
paymentCollectionMode String @default("manual")
paymentLink String?
liveStarted Boolean @default(false)
matchQuantity Int?
matchQuantityMode String @default("all")
scheduleMode String @default("single_day")
phaseSchedule String?
phaseMatchRules String?
bingoMode    String?
bingoDrawMode String?
bingoCardMode String?
bingoMaxNumber Int @default(75)
bingoCardPrice Float?
bingoCardsPerParticipant Int @default(1)
bingoDrawnNumbers String?
bingoWinners String?
bingoCurrentRound Int @default(1)
bingoRoundPrize String?
bingoRoundRule String?
bingoRoundStatus String @default("open")
bingoLastClaimAt DateTime?
bingoLastClaimName String?
  sport   Sport   @relation(fields: [sportId], references: [id])
  players Player[]
  matches Match[]
  registrations TournamentRegistration[]
  bingoCards BingoCard[]
  bingoDraws BingoDraw[]
  bingoWinnerRecords BingoWinner[]
}

model Season {
  id                  Int      @id @default(autoincrement())
  organizationId      Int
  name                String
  tournamentCount     Int
  playerCount         Int
  startDate           DateTime?
  endDate             DateTime?
  locations           String?
  rules               String?
  prize               String?
  status              String   @default("draft")
  championName        String?
  championPoints      Int?
  createdAt           DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  tournaments  Tournament[]
}

model Player {
  id           Int      @id @default(autoincrement())
  name         String
  nickname     String?
  email        String?
  phone        String?
  tournamentId Int?
  createdAt    DateTime @default(now())

  tournament Tournament? @relation(fields: [tournamentId], references: [id])
  bingoCards BingoCard[]
}

model PlayerAccount {
  id              Int      @id @default(autoincrement())
  name            String
  nickname        String?
  email           String   @unique
  phone           String?
  rg              String?
  city            String?
  state           String?
  country         String?
  favoriteSports  String?
  termsAcceptedAt DateTime?
  createdAt       DateTime @default(now())
}

model Match {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  playerAId    Int?
  playerBId    Int?
  winnerId     Int?
  loserId      Int?
  tableNumber  Int?
  round        Int
  bracketType  String
  status       String   @default("pending")
  scoreA       Int      @default(0)
  scoreB       Int      @default(0)
  resultType   String?
  calledAt     DateTime?
  startedAt    DateTime?
  callCount    Int      @default(0)
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
}

model TournamentRegistration {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  name         String
  rg           String
  email        String
  phone        String
  status       String   @default("confirmed")
  paymentStatus String  @default("pending")
  paymentMethod String?
  automaticPayment Boolean @default(false)
  mercadoPagoId String?
  paymentTicketUrl String?
  paymentQrCode String?
  paymentQrCodeBase64 String?
  representsOrganization Boolean @default(false)
  representedOrganizationName String?
  representedOrganizationType String?
  representedOrganizationDocument String?
  checkedIn    Boolean  @default(false)
  confirmationToken String? @unique
  confirmedAt   DateTime?
  sortOrder     Int?
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, email])
}

model TournamentTemplate {
  id              Int    @id @default(autoincrement())
  sportId         Int
  name            String
  playerCount     Int
  format          String
  eliminationType String

  sport Sport @relation(fields: [sportId], references: [id])
}

model BingoCard {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  playerId     Int?
  buyerName    String?
  buyerEmail   String?
  buyerWhatsapp String?
  numbers      String
  status       String   @default("pending")
  source       String   @default("online")
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  player     Player?    @relation(fields: [playerId], references: [id])
  winners    BingoWinner[]
}

model BingoDraw {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  roundName    String?
  prize        String?
  rule         String?
  number       Int
  source       String   @default("virtual")
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
}

model BingoWinner {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  cardId       Int?
  roundName    String?
  winnerName   String
  prize        String?
  rule         String?
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  card       BingoCard? @relation(fields: [cardId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  phone String?
emailVerified Boolean @default(false)
emailVerifyToken String?
passwordResetToken String?
passwordResetExpiresAt DateTime?
organizationId Int?
organization   Organization? @relation(fields: [organizationId], references: [id])
}

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
address String?
street String?
number String?
complement String?
zipCode String?
neighborhood String?
country String?
state String?
city String?
logoUrl String?
documentType String?
documentNumber String?
responsibleCpf String?
responsibleZipCode String?
responsibleStreet String?
responsibleNumber String?
responsibleComplement String?
responsibleNeighborhood String?
responsibleCity String?
responsibleState String?
kycStatus String @default("pending")
kycDocumentUrl String?
termsAcceptedAt DateTime?
paymentCollectionMode String @default("manual")
supportedSports String?
plan        String    @default("trial")
status String @default("active")
trialEndsAt DateTime?
planExpiresAt DateTime?
maxUsers Int @default(1)
tournamentCredits Int @default(0)
  users       User[]
  tournaments Tournament[]
  seasons     Season[]
}

model Payment {
  id             Int      @id @default(autoincrement())
  mercadoPagoId String?  @unique
  organizationId Int?
  plan           String
  amount         Float
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  paidAt         DateTime?
}
