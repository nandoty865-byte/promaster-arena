generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sport {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  tournaments Tournament[]
  templates   TournamentTemplate[]
}

model Tournament {
  id          Int      @id @default(autoincrement())
  name        String
  sportId     Int
  playerCount Int
  format      String
  status      String   @default("draft")
  tableCount  Int
  createdAt   DateTime @default(now())

  sport   Sport   @relation(fields: [sportId], references: [id])
  players Player[]
  matches Match[]
}

model Player {
  id           Int      @id @default(autoincrement())
  name         String
  nickname     String?
  tournamentId Int?
  createdAt    DateTime @default(now())

  tournament Tournament? @relation(fields: [tournamentId], references: [id])
}

model Match {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  playerAId    Int?
  playerBId    Int?
  winnerId     Int?
  loserId      Int?
  tableNumber  Int?
  round        Int
  bracketType  String
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
}

model TournamentTemplate {
  id              Int    @id @default(autoincrement())
  sportId         Int
  name            String
  playerCount     Int
  format          String
  eliminationType String

  sport Sport @relation(fields: [sportId], references: [id])
}
